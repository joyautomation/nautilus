name: ci
on:
  push:
  pull_request:

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          go-version: "1.24"
      - name: vet
        run: go vet ./...
      - name: check control logic
        run: go run github.com/joyautomation/nautilus/cmd/nautilus check .
      - name: test
        run: go test ./...
      - name: build
        run: go build ./...
