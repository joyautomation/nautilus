{
  "version": "0.2.0",
  "configurations": [
    {
      // Press F5 to launch a second VS Code window (the Extension
      // Development Host) with this extension loaded and the heated-tank
      // example opened as the workspace, so program.st is right there to
      // test diagnostics, go-to-definition, and live values against.
      "name": "Run Extension (heated-tank)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "${workspaceFolder}/../../examples/heated-tank"
      ],
      "outFiles": ["${workspaceFolder}/out/**/*.js"]
    }
  ]
}
