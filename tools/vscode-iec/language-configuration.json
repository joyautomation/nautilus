{
  "comments": {
    "lineComment": "//",
    "blockComment": ["(*", "*)"]
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"]
  ],
  "autoClosingPairs": [
    { "open": "(*", "close": "*)" },
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "'", "close": "'", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["'", "'"]
  ],
  "autoCloseBefore": ";:.,=}])' \n\t",
  "wordPattern": "[A-Za-z_][A-Za-z0-9_]*",
  "indentationRules": {
    "increaseIndentPattern": "(?i)\\b(PROGRAM|FUNCTION|FUNCTION_BLOCK|VAR|VAR_INPUT|VAR_OUTPUT|VAR_IN_OUT|VAR_TEMP|VAR_GLOBAL|VAR_EXTERNAL|TYPE|STRUCT|IF|ELSIF|ELSE|FOR|WHILE|REPEAT|CASE)\\b(?!.*\\b(END_IF|END_FOR|END_WHILE|END_REPEAT|END_CASE)\\b)",
    "decreaseIndentPattern": "(?i)^\\s*\\b(END_PROGRAM|END_FUNCTION|END_FUNCTION_BLOCK|END_VAR|END_TYPE|END_STRUCT|END_IF|ELSIF|ELSE|END_FOR|END_WHILE|END_REPEAT|END_CASE|UNTIL)\\b"
  }
}
